# Redis Connection String (Get this from Upstash, Render, or run locally)
REDIS_URL=redis://localhost:6379

# The API Key required for nodes to register to this cloud
# Keep this secret! Do not share it with agents.
PROVIDER_API_KEY=your_secret_provider_key_here

# The API Key required for agents to use the cloud
AGENT_API_KEY=your_secret_agent_key_here
