{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oahl.dev/schemas/execution-result.schema.json",
  "title": "OAHL Execution Result",
  "description": "Canonical structured response envelope for hardware capability execution results.",
  "type": "object",
  "required": [
    "schema_version",
    "operation_id",
    "status",
    "completion",
    "capability",
    "device_id",
    "timestamp"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "operation_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["accepted", "in_progress", "success", "error"]
    },
    "completion": {
      "type": "object",
      "required": ["done", "state"],
      "properties": {
        "done": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": ["queued", "in_progress", "completed", "failed"]
        },
        "progress_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "capability": {
      "type": "string"
    },
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "description": "Capability-specific structured payload.",
      "type": ["object", "array", "string", "number", "boolean", "null"]
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "properties": {
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "adapter_id": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
