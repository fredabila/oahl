{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAHL Configuration Schema",
  "type": "object",
  "definitions": {
    "baselineCapability": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "name": { "type": "string", "default": "hardware.baseline" },
        "description": { "type": "string" },
        "helper_url": { "type": "string" },
        "template": { "type": "string" },
        "context": { "type": "string" }
      }
    }
  },
  "properties": {
    "node_id": { "type": "string" },
    "cloud_url": { "type": "string" },
    "provider_api_key": { "type": "string" },
    "plugins": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provider": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "owner_id": { "type": "string" }
      }
    },
    "baseline_capability": {
      "$ref": "#/definitions/baselineCapability"
    },
    "server": {
      "type": "object",
      "properties": {
        "port": { "type": "number", "default": 3000 },
        "host": { "type": "string", "default": "0.0.0.0" }
      }
    },
    "adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "enabled": { "type": "boolean", "default": true },
          "config": { "type": "object" }
        },
        "required": ["type"]
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "deviceId": { "type": "string" },
          "maxDurationMs": { "type": "number" },
          "allowedCapabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "disabledCapabilities": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["deviceId"]
      }
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "adapter": { "type": "string" },
          "owner_id": { "type": "string" },
          "manufacturer": { "type": "string" },
          "model": { "type": "string" },
          "serial_number": { "type": "string" },
          "semantic_context": {
            "type": "array",
            "items": { "type": "string" }
          },
          "pricing": {
            "type": "object",
            "properties": {
              "currency": { "type": "string" },
              "rate_per_minute": { "type": "number" },
              "rate_per_execution": { "type": "number" },
              "payment_address": { "type": "string" }
            },
            "required": ["currency"]
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "baseline_capability": {
            "$ref": "#/definitions/baselineCapability"
          }
        },
        "required": ["id"]
      }
    }
  }
}
